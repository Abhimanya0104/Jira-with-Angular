{
  "version": 2,
  "framework": "angular",
  "buildCommand": "npx ng build frontend --configuration production",
  "outputDirectory": "dist/frontend/browser",
  "installCommand": "npm install",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}